# Dashban backend environment variables.
# Copy to .env for local development; set the real values in the Railway dashboard.
# NEVER commit a real .env (it is gitignored).

# Port the server listens on. Railway injects this automatically in production.
PORT=3000

# The repository the board manages (owner/name). Exposed to the browser.
GITHUB_REPO=super3/dashban

# --- Clerk ("Sign in with GitHub") ---
# Publishable key is browser-safe and has a hardcoded default in server.js, so
# you only need to set this to point at a DIFFERENT Clerk instance (e.g. a
# production pk_live_ key). Optional.
CLERK_PUBLISHABLE_KEY=
# Secret key is server-only — used to verify sessions and fetch the user's
# GitHub OAuth token. NEVER expose this to the browser. REQUIRED for the
# /api/github proxy (without it the proxy returns 503).
CLERK_SECRET_KEY=
